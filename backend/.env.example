# ─────────────────────────────────────────────────────────
# JAXI Intelligence — Environment Variables
# BIMVDC CORE · JAXI Builders, Inc.
# Copy to .env and fill in your values
# ─────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
ALLOWED_ORIGINS=http://localhost:3000

# ── Database (PostgreSQL) ─────────────────────────────────
DATABASE_URL=postgresql://jaxi_user:your_password@localhost:5432/jaxi_intelligence

# ── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT Auth ──────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-long
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Encryption (AES-256 for OAuth tokens) ─────────────────
# CRITICAL: 32 characters exactly. Keep this secret!
ENCRYPTION_KEY=your-32-char-encryption-key-here!

# ── Microsoft Outlook (Graph API) ─────────────────────────
# Register app at: https://portal.azure.com → Azure Active Directory → App registrations
# Required scopes: Mail.Read, User.Read, offline_access
MICROSOFT_CLIENT_ID=your-azure-app-client-id
MICROSOFT_CLIENT_SECRET=your-azure-app-client-secret
MICROSOFT_TENANT_ID=common
MICROSOFT_REDIRECT_URI=http://localhost:3001/api/v1/integrations/outlook/callback

# ── Procore API ───────────────────────────────────────────
# Register app at: https://developers.procore.com
PROCORE_CLIENT_ID=your-procore-client-id
PROCORE_CLIENT_SECRET=your-procore-client-secret
PROCORE_REDIRECT_URI=http://localhost:3001/api/v1/integrations/procore/callback
PROCORE_WEBHOOK_SECRET=your-procore-webhook-hmac-secret

# ── AI (Google Gemini) ────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-1.5-pro

# ── Storage (Cloudflare R2 / AWS S3) ─────────────────────
STORAGE_ENDPOINT=https://your-account.r2.cloudflarestorage.com
STORAGE_BUCKET=jaxi-files
STORAGE_ACCESS_KEY=your-storage-access-key
STORAGE_SECRET_KEY=your-storage-secret-key

# ── Email (SendGrid) ──────────────────────────────────────
SENDGRID_API_KEY=SG.your-sendgrid-api-key
EMAIL_FROM=noreply@jaxibuilders.com

# ── Frontend URL ──────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── Debug ─────────────────────────────────────────────────
LOG_QUERIES=false
