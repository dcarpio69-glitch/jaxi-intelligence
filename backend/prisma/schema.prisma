// JAXI Intelligence — Prisma Schema (SQLite compatible)
// BIMVDC CORE · JAXI Builders, Inc.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./jaxi.db"
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  name         String
  role         String    @default("PM")      // ADMIN | PM | ARCHITECT | SUBCONTRACTOR | CLIENT
  passwordHash String?
  avatarUrl    String?
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  microsoftId  String?   @unique
  procoreId    String?   @unique
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  projectMembers    ProjectMember[]
  rfisCreated       RFI[]           @relation("RFICreatedBy")
  rfisAssigned      RFI[]           @relation("RFIAssignedTo")
  submittalsCreated Submittal[]     @relation("SubmittalCreatedBy")
  comments          Comment[]
  auditEvents       AuditEvent[]
  oauthTokens       OAuthToken[]
  reviews           Review[]

  @@map("users")
}

model Project {
  id          String    @id @default(uuid())
  name        String
  code        String    @unique
  description String?
  address     String?
  city        String?
  state       String?
  status      String    @default("ACTIVE")   // ACTIVE | ON_HOLD | COMPLETED | ARCHIVED
  startDate   DateTime?
  endDate     DateTime?
  procoreId   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  members      ProjectMember[]
  rfis         RFI[]
  submittals   Submittal[]
  emailThreads EmailThread[]
  syncLogs     SyncLog[]

  @@map("projects")
}

model ProjectMember {
  id        String   @id @default(uuid())
  projectId String
  userId    String
  role      String   // PM | ARCHITECT | etc.
  joinedAt  DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@map("project_members")
}

model RFI {
  id           String    @id @default(uuid())
  projectId    String
  number       String
  title        String
  description  String
  status       String    @default("OPEN")    // DRAFT | OPEN | PENDING_REVIEW | ANSWERED | CLOSED | OVERDUE
  priority     String    @default("MEDIUM")  // LOW | MEDIUM | HIGH | CRITICAL
  discipline   String?
  dueDate      DateTime?
  answeredAt   DateTime?
  procoreId    String?
  procoreNum   Int?
  riskScore    Int?
  ballInCourt  String?
  ballInCourtCompany String?
  createdById  String
  assignedToId String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy User      @relation("RFICreatedBy", fields: [createdById], references: [id])
  assignedTo User?    @relation("RFIAssignedTo", fields: [assignedToId], references: [id])
  comments  Comment[]
  emailThreads EmailThread[]
  statusHistory StatusHistory[]

  @@map("rfis")
}

model Submittal {
  id             String    @id @default(uuid())
  projectId      String
  number         String
  title          String
  description    String?
  status         String    @default("SUBMITTED") // DRAFT | SUBMITTED | IN_REVIEW | APPROVED | APPROVED_AS_NOTED | REJECTED | RESUBMIT_REQUIRED | OVERDUE
  priority       String    @default("MEDIUM")
  discipline     String?
  specSection    String?
  packageName    String?
  submittalType  String?
  contractor     String?
  ballInCourt    String?
  ballInCourtCompany String?
  dueDate        DateTime?
  reviewedAt     DateTime?
  procoreId      String?
  procoreNum     String?
  riskScore      Int?
  currentVersion Int       @default(1)
  createdById    String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  project       Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy     User              @relation("SubmittalCreatedBy", fields: [createdById], references: [id])
  versions      SubmittalVersion[]
  reviews       Review[]
  comments      Comment[]
  emailThreads  EmailThread[]
  statusHistory StatusHistory[]

  @@map("submittals")
}

model SubmittalVersion {
  id          String   @id @default(uuid())
  submittalId String
  version     Int
  fileUrl     String
  fileName    String
  fileSize    Int
  uploadedAt  DateTime @default(now())

  submittal Submittal @relation(fields: [submittalId], references: [id], onDelete: Cascade)

  @@map("submittal_versions")
}

model Review {
  id          String   @id @default(uuid())
  submittalId String
  reviewerId  String
  action      String
  comment     String?
  reviewedAt  DateTime @default(now())

  submittal Submittal @relation(fields: [submittalId], references: [id], onDelete: Cascade)
  reviewer  User      @relation(fields: [reviewerId], references: [id])

  @@map("reviews")
}

model Comment {
  id          String   @id @default(uuid())
  content     String
  authorId    String
  rfiId       String?
  submittalId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  author    User      @relation(fields: [authorId], references: [id])
  rfi       RFI?      @relation(fields: [rfiId], references: [id], onDelete: Cascade)
  submittal Submittal? @relation(fields: [submittalId], references: [id], onDelete: Cascade)

  @@map("comments")
}

model StatusHistory {
  id          String   @id @default(uuid())
  rfiId       String?
  submittalId String?
  fromStatus  String
  toStatus    String
  changedById String?
  note        String?
  changedAt   DateTime @default(now())

  rfi       RFI?       @relation(fields: [rfiId], references: [id], onDelete: Cascade)
  submittal Submittal? @relation(fields: [submittalId], references: [id], onDelete: Cascade)

  @@map("status_history")
}

model EmailThread {
  id               String    @id @default(uuid())
  projectId        String
  rfiId            String?
  submittalId      String?
  outlookId        String    @unique
  subject          String
  senderEmail      String
  senderName       String?
  receivedAt       DateTime
  hasCommitment    Boolean   @default(false)
  commitmentDate   DateTime?
  commitmentText   String?
  commitmentStatus String?   // DETECTED | FULFILLED | BROKEN | PENDING
  sentiment        String?   // positive | neutral | negative | urgent
  createdAt        DateTime  @default(now())

  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  rfi       RFI?      @relation(fields: [rfiId], references: [id])
  submittal Submittal? @relation(fields: [submittalId], references: [id])

  @@map("email_threads")
}

model OAuthToken {
  id           String   @id @default(uuid())
  userId       String
  provider     String   // MICROSOFT_OUTLOOK | PROCORE
  accessToken  String
  refreshToken String?
  expiresAt    DateTime
  scope        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@map("oauth_tokens")
}

model SyncLog {
  id          String   @id @default(uuid())
  projectId   String
  source      String   // PROCORE | OUTLOOK
  status      String   // SUCCESS | PARTIAL | FAILED
  itemsSynced Int      @default(0)
  errors      String?
  duration    Int?
  syncedAt    DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("sync_logs")
}

model AuditEvent {
  id         String   @id @default(uuid())
  userId     String?
  action     String
  resource   String
  resourceId String?
  metadata   String?  // JSON serialized
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@map("audit_events")
}
